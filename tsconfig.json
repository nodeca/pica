{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [ "ES2020", "DOM", "WebWorker" ],
    "allowJs": false,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [ "node", "vitest/globals" ]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "vitest.config.mjs"
  ]
}
